{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Fase2CertifierOutput",
  "type": "object",
  "additionalProperties": false,
  "required": ["candidate_id", "source_kind", "authority", "identity", "page_role", "evidence_state", "bucket", "decision", "confidence", "citations", "reason", "tool_request", "learning_proposal"],
  "properties": {
    "candidate_id": {"type": "string"},
    "source_kind": {"enum": ["dominio_oficial_prefeitura", "portal_externo_delegado", "banca", "diario", "desconocido"]},
    "authority": {"enum": ["confirmada", "rechazada", "desconocida"]},
    "identity": {"enum": ["confirmada", "rechazada", "desconocida"]},
    "page_role": {"enum": ["indice_listado", "indice_combinado", "detalle_individual", "noticia", "menu_sin_listado", "incompleto_antibot", "desconocido"]},
    "evidence_state": {"enum": ["completa", "renderizada", "incompleta_antibot", "error_fetch"]},
    "bucket": {"enum": ["concurso_publico", "processo_seletivo", "combinado", "desconocido"]},
    "decision": {"enum": ["indice_oficial", "indice_oficial_combinado", "portal_externo_oficial", "detalle_individual_rechazado", "licitacao_rechazada", "concurso_cultural_rechazado", "nao_encontrado", "revisar"]},
    "confidence": {"enum": ["high", "medium", "low"]},
    "citations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["dimension", "quote", "source_field", "source_id"],
        "properties": {
          "dimension": {"enum": ["authority", "identity", "page_role", "bucket", "stability", "rejection"]},
          "quote": {"type": "string", "minLength": 1},
          "source_field": {"enum": ["title", "heading", "main_content", "event_row", "anchor", "provenance", "status"]},
          "source_id": {"type": "string", "minLength": 1},
          "start": {"type": "integer"},
          "end": {"type": "integer"}
        }
      }
    },
    "reason": {"type": "string", "minLength": 1},
    "tool_request": {
      "anyOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["tool", "args", "question"],
          "properties": {
            "tool": {"enum": ["fetch_http", "render_browser", "extract_main_content", "inspect_navigation", "inspect_links", "inspect_sitemap", "search_internal", "verify_identity", "verify_official_chain", "compare_candidates", "lookup_case_memory"]},
            "args": {"type": "object"},
            "question": {"type": "string", "minLength": 1}
          }
        }
      ]
    },
    "learning_proposal": {"type": ["object", "null"]}
  }
}
